# Firebase Realtime Database — required for cross-device multiplayer.
# Without these, the app falls back to BroadcastChannel (same-device, different tabs only).
#
# Create a free project at https://console.firebase.google.com
# Enable Realtime Database, set rules to allow read/write during development.
#
# Copy this file to .env.local and fill in your values.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
